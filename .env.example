# Chave do Gemini (Fase 10 do PLANO_IMPLEMENTACAO.md).
# Nunca expor no frontend/bundle — vive só como secret da Edge Function
# supabase/functions/gemini (configurado via `supabase secrets set`, nunca
# neste arquivo). ANTHROPIC_API_KEY não é mais usada (texto migrou p/ Gemini).
GEMINI_API_KEY=

# Supabase (Fase 11 do PLANO_IMPLEMENTACAO.md) — projeto real, ver esquema-prisma.md.
# VITE_SUPABASE_ANON_KEY é pública por design (protegida por RLS no banco),
# pode ir no bundle do frontend. NUNCA colocar aqui a service_role key.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
