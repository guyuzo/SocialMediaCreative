# Chaves usadas apenas pelo backend (Fase 10 do PLANO_IMPLEMENTACAO.md).
# Nunca expor no frontend/bundle — a UI de Criativos fala só com src/lib/ai/*,
# que hoje é mockado e na Fase 10 passa a chamar um backend que segura essas chaves.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Supabase (Fase 11 do PLANO_IMPLEMENTACAO.md) — projeto real, ver esquema-prisma.md.
# VITE_SUPABASE_ANON_KEY é pública por design (protegida por RLS no banco),
# pode ir no bundle do frontend. NUNCA colocar aqui a service_role key.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
